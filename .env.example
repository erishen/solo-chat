# Server Configuration
PORT=3002
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Asset Lens API (投资助手后端)
VITE_ASSET_LENS_API=http://localhost:8000

# Stock Analyzer API (可选)
VITE_STOCK_ANALYZER_API=http://localhost:8001

# Logging
LOG_LEVEL=info

# Sentry Configuration (Optional)
# Get your DSN from https://sentry.io/
SENTRY_DSN=
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# Vercel Deployment (生产环境)
# VITE_ASSET_LENS_API=https://your-api.vercel.app
# VITE_STOCK_ANALYZER_API=https://stock-analyzer.vercel.app

# Feature Flags
VITE_ENABLE_RAG=true
VITE_ENABLE_SIGNALS=true
VITE_ENABLE_PORTFOLIO=true
